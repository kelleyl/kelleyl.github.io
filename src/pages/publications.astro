---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Publications & Presentations — Kelley Lynch">
  <section>
    <div class="container">
      <h1>Publications & Presentations</h1>

      <!-- CLAMS Platform -->
      <div class="pub-section">
        <h2>CLAMS Platform</h2>
        <p class="section-description">
          Core developer and coauthor on publications for
          <a href="https://clams.ai" target="_blank">CLAMS</a>
          (Computational Linguistics Applications for Multimedia Services).
        </p>

        <div class="pub-list">
          <div class="pub-entry">
            <div class="pub-year">2025</div>
            <div class="pub-details">
              <h3>A Platform for AI-Assisted Archival Metadata Generation</h3>
              <p class="pub-authors">Rim, King, <strong>Lynch</strong>, Verhagen, Pustejovsky</p>
              <p class="pub-venue">HCI International 2025</p>
              <div class="pub-links">
                <a href="https://link.springer.com/chapter/10.1007/978-3-031-93160-4_12" target="_blank">Springer</a>
              </div>
            </div>
          </div>

          <div class="pub-entry">
            <div class="pub-year">2025</div>
            <div class="pub-details">
              <h3>Multimodal Interoperability with the CLAMS Platform</h3>
              <p class="pub-authors"><strong>Lynch</strong>, Rim, King, Pustejovsky</p>
              <p class="pub-venue">MultiMedia Modeling (MMM) 2025 — Demo</p>
              <div class="pub-links">
                <a href="https://scholarworks.brandeis.edu/esploro/outputs/bookChapter/Multimodal-Interoperability-withtheCLAMS-Platform/9924429173501921" target="_blank">Brandeis ScholarWorks</a>
                <a href="/papers/clams-mmm2025">[details]</a>
              </div>
            </div>
          </div>

          <div class="pub-entry">
            <div class="pub-year">2022</div>
            <div class="pub-details">
              <h3>The CLAMS Platform at Work: Processing Audiovisual Data from the American Archive of Public Broadcasting</h3>
              <p class="pub-authors">Verhagen, <strong>Lynch</strong>, Rim, Pustejovsky</p>
              <p class="pub-venue">LREC 2022</p>
              <div class="pub-links">
                <a href="https://aclanthology.org/2022.lrec-1.266/" target="_blank">ACL Anthology</a>
              </div>
            </div>
          </div>

          <div class="pub-entry">
            <div class="pub-year">2020</div>
            <div class="pub-details">
              <h3>Interchange Formats for Visualization: LIF and MMIF</h3>
              <p class="pub-authors">Rim, <strong>Lynch</strong>, Verhagen, Ide, Pustejovsky</p>
              <p class="pub-venue">LREC 2020</p>
              <div class="pub-links">
                <a href="https://aclanthology.org/2020.lrec-1.893/" target="_blank">ACL Anthology</a>
              </div>
            </div>
          </div>

          <div class="pub-entry">
            <div class="pub-year">2019</div>
            <div class="pub-details">
              <h3>Computational Linguistics Applications for Multimedia Services</h3>
              <p class="pub-authors">Rim, <strong>Lynch</strong>, Pustejovsky</p>
              <p class="pub-venue">LaTeCH-CLfL 2019</p>
              <div class="pub-links">
                <a href="https://aclanthology.org/W19-2512/" target="_blank">ACL Anthology</a>
              </div>
            </div>
          </div>

          <div class="pub-entry">
            <div class="pub-year">2019</div>
            <div class="pub-details">
              <h3>Indexing the American Archive of Public Broadcasting</h3>
              <p class="pub-authors">Pustejovsky, <strong>Lynch</strong>, Rim</p>
              <p class="pub-venue">Fantastic Futures 2019, Stanford University — Workshop</p>
            </div>
          </div>

          <div class="pub-entry">
            <div class="pub-year">2019</div>
            <div class="pub-details">
              <h3>Automated Creation of Descriptive Metadata for Large Media Archives</h3>
              <p class="pub-authors">Cariani, Pustejovsky, <strong>Lynch</strong>, Davis-Kaufman</p>
              <p class="pub-venue">Joint Technical Symposium (JTS) 2019, Amsterdam — Presentation</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Slates-500 -->
      <div class="pub-section">
        <h2>Slates-500 Dataset</h2>
        <p class="section-description">
          Multimodal dataset and evaluation pipeline for complex information extraction from archival video slates.
        </p>
        <div class="pub-list">
          <div class="pub-entry">
            <div class="pub-year"></div>
            <div class="pub-details">
              <h3>Slates-500: A Multimodal Dataset for Information Extraction from Archival Video</h3>
              <p class="pub-venue">Under review</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Hawaii Chyron Dataset -->
      <div class="pub-section">
        <h2>Hawaii Chyron Dataset</h2>
        <p class="section-description">
          Dataset for extracting Hawaiian language text from archival broadcast video using OCR and VLMs.
        </p>
        <div class="pub-list">
          <div class="pub-entry">
            <div class="pub-year"></div>
            <div class="pub-details">
              <h3>Understanding On-Screen Text: Do AI Tools Struggle with Hawaiian Chyrons?</h3>
              <p class="pub-venue">IASA Journal — In review</p>
            </div>
          </div>
          <div class="pub-entry">
            <div class="pub-year">2025</div>
            <div class="pub-details">
              <h3>Hawaii Chyron Dataset & Archival AI</h3>
              <p class="pub-venue">IASA Conference, Honolulu — Presentation</p>
            </div>
          </div>
          <div class="pub-entry">
            <div class="pub-year">2025</div>
            <div class="pub-details">
              <h3>Hawaii Chyron Dataset & Archival AI</h3>
              <p class="pub-venue">Fantastic Futures Conference — Presentation</p>
              <div class="pub-links">
                <a href="https://www.youtube.com/watch?v=zp58JtmDcuA&t=2926s" target="_blank">Video</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Video Content Summarization -->
      <div class="pub-section">
        <h2>Video Content Summarization</h2>
        <div class="pub-list">
          <div class="pub-entry">
            <div class="pub-year">2024</div>
            <div class="pub-details">
              <h3>Video Content Summarization with Large Language-Vision Models</h3>
              <p class="pub-authors"><strong>Lynch</strong>, Jiang, Lambright, Rim, Pustejovsky</p>
              <p class="pub-venue">IEEE Big Data (CAS Workshop), 2024</p>
              <div class="pub-links">
                <a href="https://ai-collaboratory.net/wp-content/uploads/2024/11/S01215_8341.pdf" target="_blank">PDF</a>
                <a href="/papers/video-summarization-ieee2024">[details]</a>
              </div>
            </div>
          </div>
          <div class="pub-entry">
            <div class="pub-year">2025</div>
            <div class="pub-details">
              <h3>Video Content Summarization with Large Language-Vision Models</h3>
              <p class="pub-venue">Boston Digital Humanities Symposium — Presentation</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  h1 {
    margin-bottom: var(--space-xl);
  }

  .pub-section {
    margin-bottom: var(--space-2xl);
  }

  .pub-section h2 {
    margin-bottom: var(--space-xs);
  }

  .section-description {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }

  .pub-list {
    display: flex;
    flex-direction: column;
  }

  .pub-entry {
    display: flex;
    gap: var(--space-lg);
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .pub-entry:last-child {
    border-bottom: none;
  }

  .pub-year {
    flex-shrink: 0;
    width: 50px;
    font-family: var(--font-serif);
    font-weight: 600;
    color: var(--color-accent);
    font-size: 0.9rem;
    padding-top: 2px;
  }

  .pub-details h3 {
    margin-bottom: 2px;
    font-size: 1rem;
  }

  .pub-authors {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 2px;
  }

  .pub-venue {
    font-size: 0.88rem;
    color: var(--color-accent);
    font-style: italic;
  }

  .pub-links {
    margin-top: var(--space-xs);
    font-size: 0.85rem;
  }

  @media (max-width: 768px) {
    .pub-entry { flex-direction: column; gap: var(--space-xs); }
    .pub-year { width: auto; }
  }
</style>
