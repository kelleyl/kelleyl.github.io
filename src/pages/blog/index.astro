---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog — Kelley Lynch" description="Writings on computational linguistics, multimodal AI, and building tools for cultural heritage archives.">
  <section>
    <div class="container">
      <h1>Blog</h1>

      {posts.length === 0 ? (
        <p class="empty-state">No posts yet — check back soon.</p>
      ) : (
        <div class="post-list">
          {posts.map(post => (
            <a href={`/blog/${post.id}`} class="post-card">
              <time datetime={post.data.date.toISOString().slice(0, 10)}>
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              {post.data.tags && (
                <div class="tag-list">
                  {post.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
                </div>
              )}
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  h1 {
    margin-bottom: var(--space-xl);
  }

  .empty-state {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .post-card {
    display: block;
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    transition: border-color 0.2s, box-shadow 0.2s;
    text-decoration: none;
    color: inherit;
  }

  .post-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .post-card time {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .post-card h2 {
    font-size: 1.25rem;
    margin: var(--space-xs) 0;
  }

  .post-card p {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-sm);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }
</style>
